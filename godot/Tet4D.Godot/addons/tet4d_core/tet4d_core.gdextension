[configuration]

entry_symbol = "tet4d_core_library_init"
compatibility_minimum = "4.4"
reloadable = true

[libraries]

macos.debug = "res://addons/tet4d_core/bin/libtet4d_core.macos.template_debug.framework"
macos.release = "res://addons/tet4d_core/bin/libtet4d_core.macos.template_release.framework"
linux.debug.x86_64 = "res://addons/tet4d_core/bin/libtet4d_core.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/tet4d_core/bin/libtet4d_core.linux.template_release.x86_64.so"
linux.debug.arm64 = "res://addons/tet4d_core/bin/libtet4d_core.linux.template_debug.arm64.so"
linux.release.arm64 = "res://addons/tet4d_core/bin/libtet4d_core.linux.template_release.arm64.so"
windows.debug.x86_64 = "res://addons/tet4d_core/bin/libtet4d_core.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/tet4d_core/bin/libtet4d_core.windows.template_release.x86_64.dll"
windows.debug.arm64 = "res://addons/tet4d_core/bin/libtet4d_core.windows.template_debug.arm64.dll"
windows.release.arm64 = "res://addons/tet4d_core/bin/libtet4d_core.windows.template_release.arm64.dll"
