{
  "schema_version": 2,
  "categories": [
    {"id": "replay", "label": "Replay"},
    {"id": "display", "label": "Display"},
    {"id": "theme", "label": "Theme"},
    {"id": "diagnostics", "label": "Diagnostics"},
    {"id": "controls_help", "label": "Controls Help"},
    {"id": "interface", "label": "Interface"},
    {"id": "accessibility", "label": "Accessibility"},
    {"id": "camera", "label": "Camera"}
  ],
  "settings": [
    {
      "id": "display.window_mode",
      "label": "Window Mode",
      "description": "Switches between a resizable window and the current display.",
      "category": "display",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "windowed",
      "options": [
        {"value": "windowed", "label": "Windowed"},
        {"value": "fullscreen", "label": "Fullscreen"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "display.windowed_size",
      "label": "Remembered Window Size",
      "description": "Stores the last safe windowed size automatically.",
      "category": "display",
      "value_type": "size",
      "control_type": "label",
      "default": [1280, 720],
      "min": [634, 660],
      "max": [16384, 16384],
      "ui_visible": false,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "display.ui_scale",
      "label": "UI Scale",
      "description": "Changes the size of menus, text, and the HUD.",
      "category": "display",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "standard",
      "options": [
        {"value": "small", "label": "Small"},
        {"value": "standard", "label": "Standard"},
        {"value": "large", "label": "Large"},
        {"value": "extra_large", "label": "Extra Large"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "display.hud_density",
      "label": "HUD Density",
      "description": "Controls how much player-facing game information is shown.",
      "category": "display",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "standard",
      "options": [
        {"value": "compact", "label": "Compact"},
        {"value": "standard", "label": "Standard"},
        {"value": "detailed", "label": "Detailed"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "display.board_detail",
      "label": "Board Detail",
      "description": "Changes grid and edge detail without changing gameplay.",
      "category": "display",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "standard",
      "options": [
        {"value": "minimal", "label": "Minimal"},
        {"value": "standard", "label": "Standard"},
        {"value": "full", "label": "Full"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "replay.playback_speed",
      "label": "Replay speed",
      "description": "Controls visual replay playback speed only. Does not change gameplay timing.",
      "category": "replay",
      "value_type": "float",
      "control_type": "slider",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "step": 0.25,
      "unit": "x",
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "replay.loop_enabled",
      "label": "Loop replay",
      "description": "Repeats the loaded replay when playback reaches the end.",
      "category": "replay",
      "value_type": "bool",
      "control_type": "checkbox",
      "default": true,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "display.show_w_labels",
      "label": "Show W labels",
      "description": "Shows W/layer labels in the replay view.",
      "category": "display",
      "value_type": "bool",
      "control_type": "checkbox",
      "default": true,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "display.projection_strength",
      "label": "Projection strength",
      "description": "Controls visual projection emphasis only. Does not change topology or coordinates.",
      "category": "display",
      "value_type": "float",
      "control_type": "slider",
      "default": 1.0,
      "min": 0.0,
      "max": 2.0,
      "step": 0.1,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "accessibility.contrast_mode",
      "label": "Contrast",
      "description": "High Contrast adds stronger outlines and non-colour distinctions.",
      "category": "accessibility",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "standard",
      "options": [
        {"value": "standard", "label": "Standard"},
        {"value": "high", "label": "High Contrast"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "accessibility.animation_mode",
      "label": "Animation",
      "description": "Reduced Motion shortens non-essential movement without changing game timing.",
      "category": "accessibility",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "standard",
      "options": [
        {"value": "reduced", "label": "Reduced Motion"},
        {"value": "standard", "label": "Standard Motion"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "theme.name",
      "label": "Theme",
      "description": "Selects the Godot shell visual theme.",
      "category": "theme",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "tron",
      "options": [
        {"value": "diagnostic", "label": "Diagnostic"},
        {"value": "plain", "label": "Plain"},
        {"value": "tron", "label": "Vector Arcade"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "camera.sensitivity",
      "label": "Camera Sensitivity",
      "description": "Changes how quickly the 3D and 4D camera responds.",
      "category": "camera",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "standard",
      "options": [
        {"value": "low", "label": "Low"},
        {"value": "standard", "label": "Standard"},
        {"value": "high", "label": "High"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "camera.invert_y",
      "label": "Invert Vertical Camera",
      "description": "Reverses vertical camera movement without changing piece or menu controls.",
      "category": "camera",
      "value_type": "bool",
      "control_type": "checkbox",
      "default": false,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "diagnostics.show_layout_bounds",
      "label": "Show layout bounds",
      "description": "Shows shell layout bounds for UI debugging.",
      "category": "diagnostics",
      "value_type": "bool",
      "control_type": "checkbox",
      "default": false,
      "authority": "godot_shell",
      "persistence": "session",
      "persist": false
    },
    {
      "id": "controls_help.show_keyboard_hints",
      "label": "Show keyboard hints",
      "description": "Shows keyboard help in the replay shell.",
      "category": "controls_help",
      "value_type": "bool",
      "control_type": "checkbox",
      "default": true,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "controls_help.contextual_help",
      "label": "Contextual Help",
      "description": "Controls when gameplay hints are shown.",
      "category": "controls_help",
      "value_type": "enum",
      "control_type": "dropdown",
      "default": "automatic",
      "options": [
        {"value": "automatic", "label": "Automatic"},
        {"value": "always", "label": "Always Visible"},
        {"value": "hidden", "label": "Hidden"}
      ],
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    },
    {
      "id": "interface.show_onboarding",
      "label": "Show guided onboarding",
      "description": "Shows the Getting Started guide when entering live modes.",
      "category": "interface",
      "value_type": "bool",
      "control_type": "checkbox",
      "default": true,
      "authority": "godot_shell",
      "persistence": "local_shell",
      "persist": true
    }
  ]
}
