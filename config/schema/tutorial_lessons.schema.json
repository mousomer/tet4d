{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tet4d/tutorial_lessons.schema.json",
  "title": "tet4d tutorial lessons schema",
  "type": "object",
  "required": [
    "schema_version",
    "board_profiles",
    "lessons"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "board_profiles": {
      "$ref": "#/$defs/boardProfiles"
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lesson"
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "boardProfile2d": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 4,
          "maximum": 40
        },
        "height": {
          "type": "integer",
          "minimum": 8,
          "maximum": 80
        }
      }
    },
    "boardProfile3d": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 4,
          "maximum": 40
        },
        "y": {
          "type": "integer",
          "minimum": 8,
          "maximum": 80
        },
        "z": {
          "type": "integer",
          "minimum": 4,
          "maximum": 40
        }
      }
    },
    "boardProfile4d": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z",
        "w"
      ],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 4,
          "maximum": 60
        },
        "y": {
          "type": "integer",
          "minimum": 8,
          "maximum": 100
        },
        "z": {
          "type": "integer",
          "minimum": 4,
          "maximum": 40
        },
        "w": {
          "type": "integer",
          "minimum": 3,
          "maximum": 20
        }
      }
    },
    "boardProfiles": {
      "type": "object",
      "required": [
        "2d",
        "3d",
        "4d"
      ],
      "properties": {
        "2d": {
          "$ref": "#/$defs/boardProfile2d"
        },
        "3d": {
          "$ref": "#/$defs/boardProfile3d"
        },
        "4d": {
          "$ref": "#/$defs/boardProfile4d"
        }
      }
    },
    "ui": {
      "type": "object",
      "required": [
        "text",
        "highlights",
        "key_prompts"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "highlights": {
          "$ref": "#/$defs/stringList"
        },
        "key_prompts": {
          "allOf": [
            {
              "$ref": "#/$defs/stringList"
            },
            {
              "minItems": 1,
              "maxItems": 1
            }
          ]
        }
      }
    },
    "gating": {
      "type": "object",
      "required": [
        "allow",
        "deny"
      ],
      "properties": {
        "allow": {
          "$ref": "#/$defs/stringList"
        },
        "deny": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "setup": {
      "type": "object",
      "properties": {
        "camera_preset": {
          "type": "string",
          "minLength": 1
        },
        "spawn_piece": {
          "type": "string",
          "minLength": 1
        },
        "starter_piece_id": {
          "type": "string",
          "minLength": 1
        },
        "board_preset": {
          "type": "string",
          "minLength": 1
        },
        "rng_seed": {
          "type": "integer"
        },
        "spawn_min_visible_layer": {
          "type": "integer",
          "minimum": 0
        },
        "bottom_layers_min": {
          "type": "integer",
          "minimum": 0
        },
        "bottom_layers_max": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "completeWhen": {
      "type": "object",
      "required": [
        "events",
        "predicates",
        "logic"
      ],
      "properties": {
        "events": {
          "allOf": [
            {
              "$ref": "#/$defs/stringList"
            },
            {
              "minItems": 1,
              "maxItems": 1
            }
          ]
        },
        "predicates": {
          "$ref": "#/$defs/stringList"
        },
        "logic": {
          "type": "string",
          "enum": [
            "all",
            "any"
          ]
        },
        "event_count_required": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9
        },
        "event_span_min_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60000
        }
      }
    },
    "step": {
      "type": "object",
      "required": [
        "id",
        "ui",
        "gating",
        "setup",
        "complete_when"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ui": {
          "$ref": "#/$defs/ui"
        },
        "gating": {
          "$ref": "#/$defs/gating"
        },
        "setup": {
          "$ref": "#/$defs/setup"
        },
        "complete_when": {
          "$ref": "#/$defs/completeWhen"
        }
      }
    },
    "lesson": {
      "type": "object",
      "required": [
        "lesson_id",
        "title",
        "mode",
        "steps"
      ],
      "properties": {
        "lesson_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "2d",
            "3d",
            "4d"
          ]
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step"
          }
        }
      }
    }
  }
}
