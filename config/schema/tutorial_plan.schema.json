{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tet4d/tutorial_plan.schema.json",
  "title": "tet4d tutorial plan schema",
  "type": "object",
  "required": [
    "schema_version",
    "plan_id",
    "title",
    "description",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    }
  },
  "$defs": {
    "modeList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "2d",
          "3d",
          "4d",
          "all"
        ]
      }
    },
    "stage": {
      "type": "object",
      "required": [
        "stage_id",
        "order",
        "title",
        "objective",
        "applies_to",
        "kind"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "applies_to": {
          "$ref": "#/$defs/modeList"
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "action_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
