{
  "version": 1,
  "scopes": {
    "order": ["general", "2d", "3d", "4d", "all"]
  },
  "groups": {
    "system": {
      "order": 10,
      "label": "General / System",
      "description": "Global actions available in all modes."
    },
    "game": {
      "order": 20,
      "label": "Gameplay",
      "description": "Piece translation, drop, and rotation actions."
    },
    "explorer": {
      "order": 30,
      "label": "Explorer Movement",
      "description": "Explorer-only traversal controls, including upward and downward movement."
    },
    "camera": {
      "order": 40,
      "label": "Camera / View",
      "description": "Board orbit, zoom, projection, and overlay controls."
    }
  },
  "editor": {
    "gameplay_buckets": {
      "translation": {
        "order": 10,
        "label": "Gameplay / Translation",
        "description": "Piece translation, gravity/drop, and movement intents."
      },
      "rotation": {
        "order": 20,
        "label": "Gameplay / Rotation",
        "description": "Piece rotation planes for the active dimension."
      },
      "other": {
        "order": 30,
        "label": "Gameplay / Other",
        "description": "Gameplay actions that are neither translation nor rotation."
      }
    }
  },
  "reference_groups": {
    "runtime_order": ["system", "game", "explorer", "camera"],
    "live_order": [
      "system",
      "game_translation",
      "game_rotation",
      "game_other",
      "explorer",
      "camera"
    ],
    "headings": {
      "system": "General / System",
      "game_translation": "Gameplay / Translation",
      "game_rotation": "Gameplay / Rotation",
      "game_other": "Gameplay / Other",
      "explorer": "Explorer Movement",
      "camera": "Camera / View"
    }
  },
  "actions": {
