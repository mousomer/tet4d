{
  "schema_version": 1,
  "manifest_id": "drift_protection",
  "hotspot_scan": {
    "roots": ["src", "cli", "tests", "tools", "scripts"],
    "top_n": 8
  },
  "thin_wrapper_budgets": [
    {"path": "cli/front.py", "max_real_loc": 720, "role": "compatibility launcher wrapper"},
    {"path": "cli/front2d.py", "max_real_loc": 24, "role": "thin 2D launcher shim"},
    {"path": "cli/front3d.py", "max_real_loc": 24, "role": "thin 3D launcher shim"},
    {"path": "cli/front4d.py", "max_real_loc": 24, "role": "thin 4D launcher shim"},
    {"path": "src/tet4d/engine/api.py", "max_real_loc": 120, "role": "small engine compatibility facade"},
    {"path": "src/tet4d/ui/pygame/front2d_game.py", "max_real_loc": 120, "role": "2D orchestration entrypoint"}
  ],
  "tutorial_copy_contract": {
    "lessons_path": "config/tutorial/lessons.json",
    "overlay_path": "src/tet4d/ui/pygame/runtime_ui/tutorial_overlay.py",
    "forbidden_prefixes": ["Goal:", "Action:"],
    "required_overlay_tokens": ["Do this:", "Tip:", "USE:"]
  }
}
