{
  "schema_version": 1,
  "manifest_id": "dedup_dead_code_rules",
  "forbidden_paths": [
    "tetris_nd/"
  ],
  "todo_backlog_rule": {
    "scope_globs": [
      "src/**/*.py",
      "tools/**/*.py",
      "scripts/**/*.py"
    ],
    "ignore_globs": [
      "tools/governance/check_dedup_dead_code_rules.py",
      "tests/**/*.py"
    ],
    "token_regex": "\\b(?:TODO|FIXME)\\b",
    "required_backlog_regex": "\\[BKL-[^\\]]+\\]"
  },
  "duplicate_functions": {
    "enabled": true,
    "strict_scope_globs": [
      "tools/governance/*.py"
    ],
    "advisory_scope_globs": [
      "src/tet4d/engine/runtime/*.py"
    ],
    "min_body_lines": 12,
    "max_allowed_duplicates_per_signature": 1,
    "exclude_function_names": [
      "main"
    ]
  }
}
