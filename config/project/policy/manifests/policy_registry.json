{
  "schema_version": 1,
  "manifest_id": "policy_registry",
  "docs_index": "docs/policies/INDEX.md",
  "policies": [
    {
      "id": "no_reinventing_wheel",
      "source": "docs/policies/POLICY_NO_REINVENTING_WHEEL.md",
      "type": "governance",
      "enforced_by": [
        "scripts/check_policy_compliance.sh"
      ],
      "owner": "governance"
    },
    {
      "id": "string_sanitation",
      "source": "docs/policies/POLICY_STRING_SANITATION.md",
      "type": "safety",
      "enforced_by": [
        "scripts/check_policy_compliance.sh"
      ],
      "owner": "governance"
    },
    {
      "id": "no_magic_numbers",
      "source": "docs/policies/POLICY_NO_MAGIC_NUMBERS.md",
      "type": "governance",
      "enforced_by": [
        "scripts/check_policy_compliance.sh"
      ],
      "owner": "governance"
    },
    {
      "id": "formatting",
      "source": "docs/policies/POLICY_FORMATTING.md",
      "type": "governance",
      "enforced_by": [
        "scripts/check_policy_compliance.sh"
      ],
      "owner": "governance"
    },
    {
      "id": "configuration_documentation",
      "source": "docs/policies/POLICY_CONFIGURATION_DOCUMENTATION.md",
      "type": "governance",
      "enforced_by": [
        "scripts/verify.sh",
        "tools/governance/generate_configuration_reference.py --check"
      ],
      "owner": "governance"
    }
  ],
  "contracts": [
    {
      "id": "canonical_maintenance",
      "path": "config/project/policy/manifests/canonical_maintenance.json",
      "validated_by": "tools/governance/validate_project_contracts.py"
    },
    {
      "id": "tech_debt_budget",
      "path": "config/project/policy/manifests/tech_debt_budgets.json",
      "validated_by": "scripts/check_architecture_metrics_soft_gate.sh"
    },
    {
      "id": "architecture_metrics",
      "path": "config/project/policy/manifests/architecture_metrics.json",
      "validated_by": "scripts/arch_metrics.py"
    },
    {
      "id": "secret_scan",
      "path": "config/project/policy/manifests/secret_scan.json",
      "validated_by": "python3 tools/governance/scan_secrets.py"
    },
    {
      "id": "contributor_directives",
      "path": "config/project/policy/manifests/contributor_directives.json",
      "validated_by": "tools/governance/validate_project_contracts.py"
    },
    {
      "id": "risk_gates",
      "path": "config/project/policy/manifests/risk_gates.json",
      "validated_by": "tools/governance/check_risk_gates.py"
    },
    {
      "id": "policy_runtime_rules",
      "path": "config/project/policy/manifests/policy_runtime_rules.json",
      "validated_by": "tools/governance/check_policy_runtime_rules.py"
    },
    {
      "id": "wheel_reuse_rules",
      "path": "config/project/policy/manifests/wheel_reuse_rules.json",
      "validated_by": "tools/governance/check_wheel_reuse_rules.py"
    },
    {
      "id": "loc_guidance",
      "path": "config/project/policy/manifests/loc_guidance.json",
      "validated_by": "tools/governance/check_loc_guidance.py"
    },
    {
      "id": "dedup_dead_code_rules",
      "path": "config/project/policy/manifests/dedup_dead_code_rules.json",
      "validated_by": "tools/governance/check_dedup_dead_code_rules.py"
    },
    {
      "id": "drift_protection",
      "path": "config/project/policy/manifests/drift_protection.json",
      "validated_by": "tools/governance/check_drift_protection.py"
    }
  ]
}
